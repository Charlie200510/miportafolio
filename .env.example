# ============================================================
#  portafolio-app - Variables de entorno (ejemplo)
# ============================================================
# Copia este archivo a .env y llena los valores. No lo subas a git.

# --- IA conversacional (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Tasas CETES (Banxico SIE) ---
# Si no tienes token, deja vacio y define overrides manuales abajo.
BANXICO_SIE_TOKEN=
CETES_28=
CETES_91=
CETES_182=
CETES_364=

# --- SMTP para alertas y magic links ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Auth ---
# URL publica de tu app (sin slash final). En dev usa http://localhost:5001.
AUTH_BASE_URL=http://localhost:5001
AUTH_MAGIC_LINK_TTL=900
AUTH_SESSION_TTL=2592000
# En dev podrias querer que el link se imprima en consola en vez de enviarse:
AUTH_MOCK_MODE=false

# --- Pagos: MercadoPago (plan $79 MXN/mes) ---
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PRECIO_MXN=79.00
MERCADOPAGO_PLAN_NOMBRE=Mi Portafolio Premium
MERCADOPAGO_BACK_URL=http://localhost:5001/static/index.html?paid=1
MERCADOPAGO_WEBHOOK_SECRET=
