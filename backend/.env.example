# ============================================================
#  Configuración de credenciales — copia a `.env` y rellena
# ============================================================
#  Este archivo es una PLANTILLA. Para activar las credenciales:
#    1. Cópialo a `.env` (sin el .example):
#         cp .env.example .env
#    2. Llena los valores con tus datos reales.
#    3. Reinicia el servidor (python3 app.py).
#  El archivo .env NO debe commitearse a git (revisa tu .gitignore).
# ============================================================

# ---- Claude / Anthropic -------------------------------------
# Crear key en: https://console.anthropic.com/settings/keys
# Habilita el "Asistente IA" y la generación cualitativa en
# Explorar (Deep Dive + Short Report).
ANTHROPIC_API_KEY=sk-ant-...

# ---- SMTP (alertas por email) -------------------------------
# Outlook / Hotmail:
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=tu_correo@outlook.com
SMTP_PASS=tu_password_o_app_password
SMTP_FROM=tu_correo@outlook.com

# Gmail (si usas Gmail en lugar de Outlook):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=app_password_de_16_chars
# SMTP_FROM=tu_correo@gmail.com

# iCloud Mail:
# SMTP_HOST=smtp.mail.me.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@icloud.com
# SMTP_PASS=app_specific_password
# SMTP_FROM=tu_correo@icloud.com

# ---- MercadoPago (pagos $79 MXN/mes) ------------------------
# Sólo si quieres habilitar suscripciones reales.
# MP_ACCESS_TOKEN=APP_USR-...
